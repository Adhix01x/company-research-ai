# ============================================================
# AI & Automation Developer Hiring API — Environment Variables
# ============================================================
# Copy this file to .env and fill in real values before running.

# --- Search API (Serper) ---
# Used for Google search results via the Serper API.
# Get your key at https://serper.dev
SERPER_API_KEY=your_serper_api_key_here

# --- AI Model API (OpenRouter) ---
# Used to call LLMs (GPT-4, Claude, etc.) through OpenRouter.
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# --- Discord Notifications ---
# Option A: Use a webhook URL (simplest setup).
# Create one at: Server Settings > Integrations > Webhooks
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# Option B: Use a bot token + channel ID (more control).
# Create a bot at https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_CHANNEL_ID=your_discord_channel_id_here
